CSS 
body {
    font-family: Arial;
    text-align: center;
    background: linear-gradient(to bottom right, #0f068a, #991219);
    color: rgb(198, 169, 65);
}

.gallery {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
}

.card {
    margin: 10px;
}

.card img {
    width: 200px;
    height: 150px;
    border-radius: 5px;
    transition: 0.3s;
}

.card img:hover {
    transform: scale(1.1);
}
