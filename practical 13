<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Practical 13 - Bootstrap Showcase</title>
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
<style>
body {
  background: linear-gradient(120deg, #e0f7fa, #ffffff);
  color: #004d40;
  font-family: 'Segoe UI', sans-serif;
}
.navbar {
  background: #00695c !important;
}
.navbar-brand, .nav-link {
  color: #e0f2f1 !important;
}
.nav-link:hover, .nav-link.active {
  color: #ffeb3b !important;
}
.section {
  padding: 60px 0;
}
.card {
  border-radius: 12px;
  border: none;
  box-shadow: 0 6px 20px rgba(0,0,0,0.1);
}
.card h5 {
  color: #00695c;
}
.btn-custom {
  border-radius: 30px;
}
.btn-primary {
  background: #00897b;
  border: none;
}
.btn-primary:hover {
  background: #00695c;
}
.btn-success {
  background: #43a047;
  border: none;
}
.form-control, .form-select {
  border-radius: 10px;
}
.breadcrumb {
  background: #e0f2f1;
  border-radius: 8px;
}
.modal-content {
  background: #f1f8e9;
  color: #004d40;
}
footer {
  background: #00695c;
  color: #e0f2f1;
}
</style>
</head>
<body>
<nav class="navbar navbar-expand-lg navbar-dark">
  <div class="container">
    <a class="navbar-brand fw-bold" href="#">Practical 13</a>
    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
      <span class="navbar-toggler-icon"></span>
    </button>
    <div class="collapse navbar-collapse" id="navbarNav">
      <ul class="navbar-nav ms-auto">
        <li class="nav-item"><a class="nav-link active" href="#">Home</a></li>
        <li class="nav-item"><a class="nav-link" href="#cards">Features</a></li>
        <li class="nav-item"><a class="nav-link" href="#form">Contact</a></li>
        <li class="nav-item"><a class="nav-link" href="#" data-bs-toggle="modal" data-bs-target="#infoModal">Info</a></li>
      </ul>
    </div>
  </div>
</nav>

<section class="text-center section">
  <div class="container">
    <h1 class="fw-bold">Bootstrap Components Showcase</h1>
    <button class="btn btn-primary btn-custom me-2" data-bs-toggle="modal" data-bs-target="#infoModal">Explore</button>
    <a class="btn btn-success btn-custom" href="#form">Contact Us</a>
  </div>
</section>

<section class="pb-2">
  <div class="container">
    <nav>
      <ol class="breadcrumb">
        <li class="breadcrumb-item"><a href="#">Home</a></li>
        <li class="breadcrumb-item"><a href="#cards">Features</a></li>
        <li class="breadcrumb-item active">Practical 13</li>
      </ol>
    </nav>
  </div>
</section>

<section id="cards" class="section">
  <div class="container">
    <h2 class="fw-bold mb-4 text-center">Features</h2>
    <div class="row g-4">
      <div class="col-md-4"><div class="card p-4"><h5>Fast</h5><p>Quick UI building with Bootstrap.</p></div></div>
      <div class="col-md-4"><div class="card p-4"><h5>Stylish</h5><p>Clean design with pastel theme.</p></div></div>
      <div class="col-md-4"><div class="card p-4"><h5>Responsive</h5><p>Works on all devices seamlessly.</p></div></div>
    </div>
  </div>
</section>

<section id="form" class="section">
  <div class="container">
    <div class="row justify-content-center">
      <div class="col-md-7">
        <h3 class="text-center mb-4 fw-bold">Contact Form</h3>
        <form>
          <div class="mb-3">
            <label class="form-label">Name</label>
            <input type="text" class="form-control" placeholder="Your name">
          </div>
          <div class="mb-3">
            <label class="form-label">Email</label>
            <input type="email" class="form-control" placeholder="your@email.com">
          </div>
          <div class="mb-3">
            <label class="form-label">Message</label>
            <textarea class="form-control" rows="4"></textarea>
          </div>
          <button type="submit" class="btn btn-success w-100 btn-custom">Submit</button>
        </form>
      </div>
    </div>
  </div>
</section>

<footer class="text-center py-3">
  <p>&copy; 2026 Practical 13 — S.B. Jain Institute of Technology</p>
</footer>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
